    "version": "0.2.0",
    "configurations": [
        {
            "name": "smirk demo",
            "type": "debugpy",
            "request": "launch",
            "program": "smirk/demo.py",
            "console": "integratedTerminal",
            "args": [
                "--input_path",
                "smirk/samples/test_image2.png",
                "--out_path",
                "demo_output",
                "--checkpoint",
                "smirk/pretrained_models/SMIRK_em1.pt",
                "--crop"
            ]
        },
        {
            "name": "Infer",
            "type": "debugpy",
            "request": "launch",
            "program": "infer_pipeline.py",
            "console": "integratedTerminal",
            "args": [
                "--input",
                "asset/lxq.jpg",
                "--out_dir",
                "demo_output/lxq",
                "--smirk_ckpt",
                "smirk/pretrained_models/SMIRK_em1.pt",
                "--facecheck_ckpt",
                "outputs/facecheck/best.pt"
            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}